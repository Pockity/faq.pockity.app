{
  "name": "@dz/docs-theme",
  "version": "2.0.0",
  "description": "A documentation theme for Eleventy mimicking Apple Developer Documentation",
  "main": ".eleventy.js",
  "files": [
    ".eleventy.js",
    "src/_includes",
    "src/css",
    "src/js",
    "src/images"
  ],
  "scripts": {
    "build": "npx @11ty/eleventy",
    "serve": "npx @11ty/eleventy --serve"
  },
  "dependencies": {
    "@11ty/eleventy-navigation": "^0.3.5",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "eleventy-plugin-toc": "^1.1.5",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.1.6"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0"
  }
}
