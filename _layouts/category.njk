---
layout: base
---

<div class="category-overview">
  {{ content | safe }}
</div>

{% set navPages = collections.all | eleventyNavigation %}
{% set categoryEntry = null %}
{%- for entry in navPages -%}
  {%- if entry.key == eleventyNavigation.key -%}
    {%- set categoryEntry = entry -%}
  {%- endif -%}
{%- endfor -%}

{%- if categoryEntry and categoryEntry.children.length > 0 -%}
  <section class="category-sections">
    <ul class="category-list">
      {%- for child in categoryEntry.children -%}
        <li class="category-item">
          <a href="{{ child.url | url }}" class="category-link">
            <span class="category-item-title">{{ child.title }}</span>
            <svg class="category-item-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </section>
{%- endif -%}
